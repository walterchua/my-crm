generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url      = env("DATABASE_URL")
}

// CLIENT — the merchant using your CRM
model Client {
  id           String        @id @default(cuid())
  name         String
  slug         String        @unique
  createdAt    DateTime      @default(now())
  members      Member[]
  config       ClientConfig?
  // Direct relations to Transaction and Voucher allow client-scoped
  // queries without joining through Member every time
  transactions Transaction[]
  vouchers     Voucher[]
}

// CLIENT CONFIG — rules per merchant, no hardcoding
model ClientConfig {
  id             Int    @id @default(autoincrement())
  clientId       String @unique
  earnRate       Float  @default(1.0)
  tierSilver     Int    @default(500)
  tierGold       Int    @default(2000)
  expiryDays     Int    @default(365)
  pointsToRedeem Int     @default(500)
  welcomeBonus   Int     @default(0)
  birthdayBonus  Boolean @default(false)
  client         Client  @relation(fields: [clientId], references: [id])
}

// MEMBER — the end customer
model Member {
  id           String        @id @default(cuid())
  clientId     String
  name         String
  email        String
  points       Int           @default(0)
  tier         String        @default("Bronze")
  createdAt    DateTime      @default(now())
  client       Client        @relation(fields: [clientId], references: [id])
  transactions Transaction[]
  vouchers     Voucher[]

  // email must be unique per client, not globally —
  // the same person can be a member of multiple merchants
  @@unique([clientId, email])

  // Speeds up: prisma.member.findMany({ where: { clientId } })
  // Every member list page filters by clientId — without this index
  // Postgres scans every row in the table as the member count grows.
  @@index([clientId])
}

// TRANSACTION — every earn and redeem event
model Transaction {
  id            Int      @id @default(autoincrement())
  clientId      String
  memberId      String
  type          String
  pointsBefore  Int
  pointsAfter   Int
  pointsChanged Int
  amount        Float    @default(0)
  createdAt     DateTime @default(now())
  client        Client   @relation(fields: [clientId], references: [id])
  member        Member   @relation(fields: [memberId], references: [id])

  // Speeds up: prisma.transaction.findMany({ where: { memberId } })
  // Transaction history for a single member — common on the member detail page.
  @@index([memberId])

  // Speeds up: prisma.transaction.findMany({ where: { clientId } })
  // Client-scoped transaction reports — required by Architecture Rule #1.
  @@index([clientId])
}

// USER — admin accounts that can log in to the platform
// Passwords are stored as bcrypt hashes — never plain text
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

// VOUCHER — issued to member on redemption
model Voucher {
  id         Int      @id @default(autoincrement())
  clientId   String
  memberId   String
  code       String   @unique
  value      Float
  status     String   @default("active")
  expiryDate DateTime
  createdAt  DateTime @default(now())
  client     Client   @relation(fields: [clientId], references: [id])
  member     Member   @relation(fields: [memberId], references: [id])

  // Speeds up: prisma.voucher.findMany({ where: { memberId } })
  // All vouchers issued to a specific member — shown on the member detail page.
  @@index([memberId])

  // Speeds up: prisma.voucher.findMany({ where: { clientId } })
  // Client-scoped voucher lookups — required by Architecture Rule #1.
  @@index([clientId])
}